{
  "name": "@nest-warden/example-nestjs-app",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "Runnable MVP demonstrating nest-warden in a real NestJS + TypeORM + Postgres app, with RLS policies enforced at the database layer.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --import tsx src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres"
  },
  "dependencies": {
    "@casl/ability": "^6.8.1",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/typeorm": "^10.0.2",
    "nest-warden": "file:../..",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20.16.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ]
  }
}
